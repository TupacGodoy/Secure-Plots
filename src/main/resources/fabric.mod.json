{
  "schemaVersion": 1,
  "id": "secure-plots",
  "version": "1.0.1",
  "name": "Secure Plots",
  "description": "Territory protection mod for Fabric servers. Claim land with plot blocks, manage members and roles, upgrade tiers, set ambient effects, and customize a fully animated border — all server-side configurable.",
  "authors": [
    "zhilius"
  ],
  "contact": {
    "sources": "https://github.com/TupacGodoy/Secure-Plots",
    "issues": "https://github.com/TupacGodoy/Secure-Plots/issues",
    "email": "zhilius.t@gmail.com",
    "ko-fi": "https://ko-fi.com/zhilius"
  },
  "license": "GPL-3.0-only",
  "icon": "assets/secure-plots/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "com.zhilius.secureplots.SecurePlots"
    ],
    "client": [
      "com.zhilius.secureplots.client.SecurePlotsClient"
    ]
  },
  "mixins": [
    "secure-plots.mixins.json",
    {
      "config": "secure-plots.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=0.15.0",
    "minecraft": "~1.21.1",
    "java": ">=21",
    "fabric-api": "*"
  },
  "accessWidener": "secure-plots.accesswidener"
}
